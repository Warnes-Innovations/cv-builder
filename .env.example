# Environment Variables for CV Builder
# Copy this file to .env and fill in your API keys
# DO NOT commit .env to git - it contains sensitive credentials

# GitHub Models (uses GitHub Copilot subscription)
# Get token from: https://github.com/settings/tokens
# Required scope: read:user
GITHUB_MODELS_TOKEN="TOKEN_GOES_HERE"

# OpenAI
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Override config.yaml settings via environment variables
# CV_MASTER_DATA_PATH=~/CV/Master_CV_Data.json
# CV_PUBLICATIONS_PATH=~/CV/publications.bib
# CV_OUTPUT_DIR=~/CV/cv-builder
# CV_LLM_PROVIDER=github
# CV_LLM_MODEL=gpt-4o
