{
  "name": "cv-builder",
  "version": "1.0.0",
  "private": true,
  "description": "CV Builder web UI JavaScript tests",
  "scripts": {
    "build":                    "node scripts/build.mjs",
    "build:prod":               "node scripts/build.mjs --prod",
    "build:watch":              "node scripts/build.mjs --watch",
    "build:sourcemap":          "node scripts/build.mjs --sourcemap",
    "test:js":                  "vitest run tests/js",
    "test:js:watch":            "vitest tests/js",
    "test:js:cover":            "vitest run tests/js --coverage",
    "test:integration:headless":"node web/tests/integration/run_integration.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.4",
    "jsdom": "^26.0.0",
    "playwright": "^1.42.0",
    "vitest": "^3.0.0"
  }
}
