{
  "name": "cv-builder",
  "version": "1.0.0",
  "private": true,
  "description": "CV Builder web UI JavaScript tests",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:prod": "node scripts/build.mjs --prod",
    "build:watch": "node scripts/build.mjs --watch",
    "build:sourcemap": "node scripts/build.mjs --sourcemap",
    "test:js": "NODE_NO_WARNINGS=1 vitest run tests/js",
    "test:js:watch": "NODE_NO_WARNINGS=1 vitest tests/js",
    "test:js:cover": "NODE_NO_WARNINGS=1 vitest run tests/js --coverage",
    "test:integration:headless": "node web/tests/integration/run_integration.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.4",
    "jsdom": "^26.0.0",
    "playwright": "^1.42.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "loglevel": "^1.9.2",
    "marked": "^17.0.5"
  }
}
