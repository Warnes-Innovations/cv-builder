#
# config.yaml.example — copy this to config.yaml and customise for your installation.
#
# config.yaml is gitignored because it contains personal paths and API keys.
#
# Configuration precedence (highest to lowest):
#   1. Environment variables (CV_LLM_PROVIDER, OPENAI_API_KEY, etc.)
#   2. .env file in the project root (optional — for CI/container deployments)
#   3. config.yaml  api_keys.*  (preferred for personal local use — this file)
#   4. Code defaults
#
# To set API keys via the web UI, open the LLM Configuration Wizard (⚙ button
# in the app header) and walk through the API Key / Auth step.  The wizard
# writes keys to the api_keys section below.

# ── Data paths ────────────────────────────────────────────────────────────────
data:
  master_cv:    ~/CV/Master_CV_Data.json
  publications: ~/CV/publications.bib
  output_dir:   ~/CV/cv-builder

# ── LLM settings ──────────────────────────────────────────────────────────────
# default_provider must be set (no built-in default).
# Supported providers: copilot-oauth | copilot | copilot-sdk | github |
#                      openai | anthropic | gemini | groq | local
llm:
  default_provider: github
  default_model:    null          # null = provider default
  temperature:      0.7
  max_tokens:       null          # null = provider default
  request_timeout_seconds: 120

# ── API keys ──────────────────────────────────────────────────────────────────
# Store your LLM provider credentials here.  These are read at the lowest
# priority — environment variables and .env entries take precedence.
#
# Leave a value empty ("") if you do not use that provider.
# For copilot-oauth, no key is needed here — authenticate via the wizard.
# For copilot-sdk, run `gh auth login` in a terminal instead.
api_keys:
  github_token:      ""     # GITHUB_MODELS_TOKEN — used by: github, copilot
  openai_api_key:    ""     # OPENAI_API_KEY      — used by: openai
  anthropic_api_key: ""     # ANTHROPIC_API_KEY   — used by: anthropic
  gemini_api_key:    ""     # GEMINI_API_KEY / GOOGLE_API_KEY — used by: gemini
  groq_api_key:      ""     # GROQ_API_KEY        — used by: groq

# ── Document generation ───────────────────────────────────────────────────────
generation:
  base_font_size: 13px
  max_skills:       20
  max_achievements:  5
  max_publications: 10
  page_margin:     0.5in
  page_count:
    warn_single:  true
    ideal_min:    2
    ideal_max:    3
    absolute_max: 4
  formats:
    ats_docx:   true
    human_pdf:  true
    human_docx: true
  skills_section_title: Skills

# ── Session persistence ───────────────────────────────────────────────────────
session:
  auto_save:    true
  session_dir:  ~/CV/cv-builder/sessions
  history_file: ~/CV/cv-builder/input_history

# ── Web server ────────────────────────────────────────────────────────────────
web:
  host:  127.0.0.1
  port:  5001
  debug: false

# ── Logging ───────────────────────────────────────────────────────────────────
logging:
  level:   INFO
  file:    cv-builder.log
  log_dir: ~/CV/cv-builder/logs

# ── Google Drive sync (optional) ─────────────────────────────────────────────
# Prefer OS-level Google Drive Desktop sync over the API integration.
google_drive:
  enabled:          false
  credentials_path: ~/CV/google_credentials.json
  token_path:       ~/CV/google_token.json
